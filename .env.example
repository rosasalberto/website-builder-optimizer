# ─────────────────────────────────────────────────────────────────────────────
# Website Builder Optimizer — environment
# Copy to `.env` (gitignored) or run `pnpm setup` to generate it interactively.
# Only the CORE block is required. Each integration block is OPTIONAL — fill it
# in only when you enable that feature.
# ─────────────────────────────────────────────────────────────────────────────

# ── CORE (required) ──────────────────────────────────────────────────────────
# Postgres for production (Neon pooled URL recommended), or SQLite for local:
#   Postgres:  postgres://user:pass@host/db?sslmode=require
#   SQLite:    file:./payload.db
DATABASE_URI=file:./payload.db
# For Postgres migrations only (Neon DIRECT, non-pooled). Optional for SQLite.
DATABASE_URI_DIRECT=
# Long random string — `openssl rand -hex 32`. Required.
PAYLOAD_SECRET=
# Canonical site URL, no trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# development | preview | production  (gates noindex/robots)
NEXT_PUBLIC_VERCEL_ENV=development

# ── MEDIA STORAGE (optional — pick one; defaults to local disk in dev) ───────
# Vercel Blob:
BLOB_READ_WRITE_TOKEN=
# …or S3 / R2:
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ── LEAD FORM (optional) ─────────────────────────────────────────────────────
# Forward submissions to a webhook (Zapier/Make/n8n) …
FORM_WEBHOOK_URL=
FORM_WEBHOOK_SECRET=
# …or send via Resend:
RESEND_API_KEY=

# ── ON-DEMAND REVALIDATION (optional, split-deploy only) ─────────────────────
PAYLOAD_REVALIDATE_SECRET=
# API key of a Payload user, used by scripts/blog/publish.ts over REST.
PAYLOAD_API_KEY=

# ── ANALYTICS (optional, public IDs only — safe to expose) ───────────────────
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_GSC_VERIFICATION=

# ── SKILL: blog translation + image generation (optional) ────────────────────
# Used by scripts/blog/* and the blog-publisher skill.
OPENROUTER_API_KEY=

# ── SKILL: GA4 + Search Console (optional, read-only) ────────────────────────
# One Google OAuth client + one refresh token covers BOTH GA4 and GSC.
# Mint the refresh token once with: node scripts/mint-google-refresh-token.mjs
GOOGLE_WORKSPACE_CLI_CLIENT_ID=
GOOGLE_WORKSPACE_CLI_CLIENT_SECRET=
GOOGLE_ANALYTICS_REFRESH_TOKEN=
# Property + site to report on:
GA4_PROPERTY_ID=
GSC_SITE_URL=

# ── SKILL: PageSpeed Insights (optional) ─────────────────────────────────────
PAGESPEED_API_KEY=

# ── SKILL: Google Ads (optional) ─────────────────────────────────────────────
# Mint the refresh token once with: node scripts/mint-google-ads-token.mjs
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_ID=
